# Per-project deploy configuration. Copy this file to `.env` and fill in real values.
# `.env` is gitignored; this template is committed.

# SFTP host (Domeneshop uses login.domeneshop.no for shared webhotels)
DEPLOY_HOST=

# Your SFTP username
DEPLOY_USER=

# Remote path on the server. NO trailing slash. This is the folder that will be
# mirrored to — `--delete` removes anything in it that isn't in your local _site/.
# Domeneshop example: /home/N/x/user/yourdomain.tld
DEPLOY_REMOTE=

# Path to the private SSH key. Optional — defaults to ~/.ssh/id_ed25519.
# Use Git Bash forward-slash form (e.g. /e/www/your_key) and avoid spaces.
DEPLOY_KEY=
